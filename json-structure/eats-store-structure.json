{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/uber-eats/refs/heads/main/json-structure/eats-store-structure.json",
  "name": "Store",
  "description": "Store schema from Uber Eats Marketplace API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "del_aBc123XyZ"
    },
    "name": {
      "type": "string",
      "example": "Example Store"
    },
    "contact_emails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "partner_identifiers": {
      "type": "object"
    },
    "timezone": {
      "type": "string",
      "example": "America/New_York"
    },
    "location": {
      "type": "object"
    },
    "web_url": {
      "type": "string",
      "example": "https://www.ubereats.com/orders/del_aBc123XyZ"
    }
  }
}